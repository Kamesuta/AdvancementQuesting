{
  "name": "advancement-questing-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n \"mock,vite\" -c \"cyan,green\" \"npm run mock\" \"vite\"",
    "mock": "tsx watch mock-server/index.ts",
    "mock:seed": "tsx mock-server/db/seed.ts",
    "build:assets": "npm run build --prefix asset-atlas-builder",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.80.6",
    "@xyflow/react": "^12.6.4",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-grid-layout": "^2.2.3",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.6.2",
    "recharts": "^3.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.1.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@types/react-grid-layout": "^1.3.6",
    "@vitejs/plugin-react": "^4.5.2",
    "better-sqlite3": "^11.10.0",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "dotenv": "^16.5.0",
    "drizzle-kit": "^0.31.1",
    "drizzle-orm": "^0.43.1",
    "express": "^5.1.0",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
