{
  "name": "advancement-questing-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n \"mock,vite\" -c \"cyan,green\" \"npm run mock\" \"vite\"",
    "mock": "tsx watch mock-server/index.ts",
    "mock:seed": "tsx mock-server/db/seed.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2",
    "@tanstack/react-query": "^5.80.6",
    "@xyflow/react": "^12.6.4",
    "react-markdown": "^10.1.0",
    "lucide-react": "^0.511.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "tailwindcss": "^4.1.8",
    "@tailwindcss/vite": "^4.1.8",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.4",
    "express": "^5.1.0",
    "@types/express": "^5.0.3",
    "drizzle-orm": "^0.43.1",
    "drizzle-kit": "^0.31.1",
    "better-sqlite3": "^11.10.0",
    "@types/better-sqlite3": "^7.6.13",
    "cors": "^2.8.5",
    "@types/cors": "^2.8.17",
    "dotenv": "^16.5.0"
  }
}
